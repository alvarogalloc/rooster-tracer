ROOSTERSCENEV1

# 01 - Plane + primitives baseline
viewport 1920 1080
fov 58
camera 0 1.3 5.5   0 0 -3   0 1 0   0.001 80
background 18 28 44
max_depth 5

mat 180 175 165
dir_light -1 -1 -0.3 255 245 230 0.9
point_light 2.2 2.8 1.8 255 220 180 3.2

# floor and back wall
plane 0 -1 0   0 1 0   0
plane 0 0 -10  0 0 1   0

# mixed primitives
sphere -1.3 -0.25 -4.0  0.75  255 110 110
sphere  1.2 -0.45 -3.1  0.55  110 180 255
triangle -0.2 -1.0 -2.3   0.8 0.5 -2.8   1.7 -1.0 -3.6   245 210 90
